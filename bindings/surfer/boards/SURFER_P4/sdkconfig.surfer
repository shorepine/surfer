# ESP32-P4-Function-EV-Board: 32MB hex-mode PSRAM @ 200MHz, 16MB flash.
# Same memory config the surfer M2 benchmarks ran under.
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
# copied into the MP port dir by `make mpy-p4` (IDF resolves it there)
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions-surfer-16MiB.csv"
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_360=y
